        <mapper resource="batis/MineType.xml" />
        <mapper resource="batis/Documento.xml" />
        <mapper resource="batis/EtiquetaDocu.xml" />
        <mapper resource ="batis/TipoDocumento.xml" />
        <mapper resource ="batis/MetaData.xml" />
        <mapper resource ="batis/Repositorio.xml" />
        <mapper resource ="batis/Catalogo.xml" />
        <mapper resource ="batis/Categoria.xml" />
        <mapper resource ="batis/Permiso.xml" />
        <mapper resource ="batis/Notificacion.xml" />
        <mapper resource ="batis/Grupo.xml" />
        
        <!--Siado-->
        <mapper resource ="batis/Siado.xml" />
        <mapper resource ="batis/SiadoDetalle.xml" />
        <!--WebPersonal/WebRrhh -->
        <mapper resource ="batis/Personal.xml" />
        
