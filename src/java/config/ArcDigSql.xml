        <!--Siado-->
             
        <typeAlias alias="Personal" type="gob.peam.arcdig.beans.Personal" />
    </typeAliases>
    
    <environments default="ArcDig">
        <environment id="SISAI">
            <transactionManager type="JDBC"/>
            <dataSource type="POOLED">
                <property name="driver" value="org.postgresql.Driver"/>
                <property name="url" value="jdbc:postgresql://172.16.100.25:5432/ArcDigAR"/>
                <property name="username" value="postgres"/>
                <property name="password" value=""/>
            </dataSource>
        </environment>
        
        <environment id="ArcDig">
            <transactionManager type="JDBC"/>
            <dataSource type="POOLED">
                <property name="driver" value="org.postgresql.Driver"/>
                <property name="url" value="jdbc:postgresql://172.16.100.25:5433/ArcDigAR"/>
                <property name="username" value="postgres"/>
                <property name="password" value=""/>
            </dataSource>
        </environment>
        
        <environment id="WebPersonal">
            <transactionManager type="JDBC"/>
            <dataSource type="POOLED">
                <property name="driver" value="org.postgresql.Driver"/>
                <property name="url" value="jdbc:postgresql://172.16.100.25:5432/ArcDigAR"/>
                <property name="username" value="postgres"/>
                <property name="password" value=""/>
            </dataSource>
        </environment>
        
    </environments>
   
    <mappers>
        
        <!--WebApp-->
        <mapper resource="batis/Usuario.xml" />
        <mapper resource="batis/Sesion.xml" />
        <mapper resource="batis/Etiqueta.xml" />
        <mapper resource="batis/Persona.xml" />
        <mapper resource="batis/Entidad.xml" />
        <mapper resource="batis/Dependencia.xml" />
        
