        <typeAlias alias="Dependencia" type="gob.peam.arcdig.beans.Dependencia" />
        <typeAlias alias="Persona" type="gob.peam.arcdig.beans.Persona" />
        <typeAlias alias="Grupo" type="gob.peam.arcdig.beans.Grupo" />
        <typeAlias alias="Etiqueta" type="gob.peam.arcdig.beans.Etiqueta" /> 
        <typeAlias alias="SubModulo" type="gob.peam.arcdig.beans.SubModulo" />
