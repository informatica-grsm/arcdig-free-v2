			<parameterDescription><![CDATA[]]></parameterDescription>
			<defaultValueExpression><![CDATA["Total tipo documento:"+ $V{total_tipo}]]></defaultValueExpression>
		</parameter>
		<parameter name="query" class="java.lang.String"/>
		<queryString>
			<![CDATA[select * from documento
inner join tipo_documento on documento.tido_id = tipo_documento.tido_id
where cata_id = $P{cata_id} $P!{query}
order by documento.tido_id  asc, documento.docu_hora desc]]>
		</queryString>
		<field name="docu_id" class="java.lang.Integer"/>
		<field name="usua_id" class="java.lang.Integer"/>
