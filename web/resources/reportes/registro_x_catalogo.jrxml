	<subDataset name="totales" uuid="530603d2-cf0d-4782-8bf7-c4f803d214c0">
		<parameter name="query" class="java.lang.String"/>
		<queryString>
			<![CDATA[select count(documento.tido_id) total, tido_nombre from documento
inner join tipo_documento on tipo_documento.tido_id = documento.tido_id
where docu_estado = true $P!{query}
group by documento.tido_id, tido_nombre]]>
		</queryString>
		<field name="total" class="java.lang.Long"/>
		<field name="tido_nombre" class="java.lang.String"/>
	</subDataset>
	<parameter name="query" class="java.lang.String"/>
	<parameter name="entidad" class="java.lang.String"/>
	<queryString>
		<![CDATA[select distinct(catalogo.cata_nombre), catalogo.cata_id from catalogo
inner join documento on documento.cata_id = catalogo.cata_id
where catalogo.cata_eliminado = false  $P!{query}]]>
	</queryString>
	<field name="cata_nombre" class="java.lang.String"/>
	<field name="cata_id" class="java.lang.Integer"/>
