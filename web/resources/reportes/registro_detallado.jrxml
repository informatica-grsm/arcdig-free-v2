	<subDataset name="resumen" uuid="61882b87-0bb1-44e7-bac3-edab52ea36c1">
		<parameter name="tido_nombre" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="tido_id" class="java.lang.Integer"/>
		<parameter name="labelTotalTipo" class="java.lang.String" isForPrompting="false">
			<parameterDescription><![CDATA[]]></parameterDescription>
			<defaultValueExpression><![CDATA["Total tipo documento:"]]></defaultValueExpression>
		</parameter>
		<parameter name="query" class="java.lang.String">
			<parameterDescription><![CDATA[]]></parameterDescription>
		</parameter>
		<queryString>
			<![CDATA[select *, replace(replace(replace (replace (replace (replace (replace (replace (replace (docu_metadata, '</meta_descripcion>', '; </i>'), '<meta_descripcion>', '<i>'), '</meta_nombre>', ': </b>'), '<meta_nombre>', '<b>'), '<meta_id>', '<b>'), '</meta_id>', '. </b>'), '<meta_id>', '<b>'), '</docu_metadata>', '</p>'), '<docu_metadata>', '<p>') campo
from documento d
inner join categoria c on d.cate_id = c.cate_id
inner join tipo_documento t on t.tido_id = d.tido_id
where d.docu_estado = true
order by d.cate_id asc, d.tido_id  asc, d.docu_hora desc]]>
		</queryString>
		<field name="docu_id" class="java.lang.Integer"/>
		<field name="usua_id" class="java.lang.Integer"/>
