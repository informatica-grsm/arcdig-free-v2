	<subDataset name="resumen" uuid="61882b87-0bb1-44e7-bac3-edab52ea36c1">
		<parameter name="query" class="java.lang.String"/>
		<queryString>
			<![CDATA[select documento.docu_id,docu_titulo, docu_hora, propietario, docu_resumen,
case when string_agg(cast(etiqueta.etiq_nombre as varchar), ' ; ')  is null then 'NO TIENE' else string_agg(cast(etiqueta.etiq_nombre as varchar), ' ; ') end etiqueta,
tipo_documento.tido_nombre, catalogo.cata_nombre
from documento
left join mine_type on documento.docu_mime_types = mine_type.mine_nombre
left join documento_etiqueta on documento_etiqueta.docu_id = documento.docu_id
left join etiqueta on etiqueta.etiq_id = documento_etiqueta.etiq_id
left join tipo_documento on documento.tido_id = tipo_documento.tido_id
left join categoria on categoria.cate_id = documento.cate_id
left join catalogo on catalogo.cata_id = documento.cata_id
where documento.docu_estado = true $P!{query}
group by documento.docu_id, docu_titulo, docu_hora, propietario, docu_resumen, tido_nombre, cata_nombre, docu_fecha
order by documento.docu_fecha desc, documento.docu_hora desc]]>
		</queryString>
		<field name="docu_id" class="java.lang.Integer"/>
		<field name="docu_titulo" class="java.lang.String"/>
		<field name="docu_hora" class="java.sql.Timestamp"/>
		<field name="propietario" class="java.lang.String"/>
		<field name="docu_resumen" class="java.lang.String"/>
		<field name="etiqueta" class="java.lang.String"/>
		<field name="tido_nombre" class="java.lang.String"/>
		<field name="cata_nombre" class="java.lang.String"/>
		<variable name="ind" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$F{docu_id}]]></variableExpression>
		</variable>
	</subDataset>
	<parameter name="query" class="java.lang.String"/>
	<parameter name="entidad" class="java.lang.String"/>
	<queryString>
		<![CDATA[select docu_id from documento
where documento.docu_estado = false
limit 1 offset 0]]>
	</queryString>
	<field name="docu_id" class="java.lang.Integer"/>
