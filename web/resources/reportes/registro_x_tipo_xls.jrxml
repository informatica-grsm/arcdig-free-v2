	<parameter name="query" class="java.lang.String"/>
	<parameter name="entidad" class="java.lang.String"/>
	<queryString>
		<![CDATA[select distinct(tipo_documento.tido_nombre), tipo_documento.tido_id from tipo_documento
inner join documento on documento.tido_id = tipo_documento.tido_id
where tipo_documento.tido_estado = true  $P!{query}]]>
	</queryString>
	<field name="tido_nombre" class="java.lang.String"/>
	<field name="tido_id" class="java.lang.Integer"/>
