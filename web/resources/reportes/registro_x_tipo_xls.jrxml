			<variableExpression><![CDATA[$F{docu_titulo}]]></variableExpression>
		</variable>
		<variable name="prueba" class="java.lang.String">
			<variableExpression><![CDATA["<p><b>1</b><b>DNI</b><i>00830221</i></p>"]]></variableExpression>
		</variable>
