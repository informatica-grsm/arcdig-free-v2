                            <listbox id="listDocumento" emptyMessage="No hay Registros Encontrados"  checkmark="true"  nonselectableTags="button">
                                <listhead>
                                    <listheader label="" width="30px"></listheader>
                                    <listheader label="Opción" width="150px"></listheader>
                                    <listheader label="Documento" width="300px" visible="false"> </listheader>
                                    <listheader label="Tipo Documental" width="200px"></listheader>
                                    <listheader label="SubTipo Documental" width="200px"></listheader>
                                    <listheader label="Det. SubTipo Documental" width="200px"></listheader>
                                    <listheader label="NumZafra" width="100px"></listheader>
                                    <listheader label="Numero" width="200px"></listheader>
                                    <listheader label="Descripción" width="200px"></listheader>
                                    <listheader label="Observación" width="100px"></listheader>
                                    <listheader label="Regente" width="100px"></listheader>
                                    <listheader label="Año Aprobación" width="100px"></listheader>
                                    <listheader label="Año fin" width="100px"></listheader>
                                    <listheader label="Titular" width="150px"></listheader>
                                    <listheader label="Fecha envio" visible="false"></listheader>
                                    
                                </listhead>
                                <auxhead id="auxHead" visible="false">
