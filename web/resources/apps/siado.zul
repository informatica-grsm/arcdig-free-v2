        <popup id="popExpediente"  style=" width:760px; ">
            <listbox id="gridDocuments" emptyMessage="No hay Registros Encontrados" mold="paging" pageSize="9"   checkmark="true"  nonselectableTags="">
              <auxhead sclass="category-center">                        
                  <auxheader style="text-align:right"  colspan="6">
                      <bandbox width="550px" id="filtroDoc" instant="true" placeholder="Buscar..." sclass="input-prepend" />
                  </auxheader>
              </auxhead>
              <listhead sizable="true">
                  <listheader hflex="min" label="" align="center"/>
                  <listheader hflex="min" label="Nro" align="center"/>
                  <listheader hflex="min" label="Doc ID" align="center"/>
                  <listheader label="Doc Titulo" align="center"/>
                  <listheader  label="Propietario" align="left"/>
                  <listheader label="Opción" width="50px"></listheader>
              </listhead>
            </listbox>
