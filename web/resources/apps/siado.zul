    <style>
        .z-datebox a{
        height: 35px !important;                    
        }
        .z-datebox a i{
        margin-top: 5px !important;  
        float: left;
        }
        .z-datebox input{
        height: 35px !important;
        }

        .z-timebox input{
        height: 35px !important;
        }

        .z-timebox span{
        height: 35px !important;
        }
    </style>
    
    <div apply='gob.peam.arcdig.view.AppSiado'>  
        
        <panel border="normal" sclass="conversation" >
            <caption iconSclass="z-icon-signal" >
              
            </caption>
            <panelchildren>
                <div class="box box-info">      
           
            
                    <popup id="popupBack"  style=" width:360px; height:105px;" >
                        <grid>
                            <columns>
                                <column label="" width="30%" align="right" />
                                <column label="" width="70%" align="left" />
                            </columns>
                            <rows>
                                <row>
                                    <label value="Nro de Tramite:"></label>
                                    <textbox id="txtExpediente"></textbox>
                                </row>
                                <row>
                                    <label />
                                    <button id="btnVerificar">Verificar</button>
                                </row>
                            
                            </rows> 
                        </grid>
                    </popup>
               
                    <div id="nDivlistaRegistro" visible="true">
                        <vlayout  style="     border: 1px solid #f9dd34;    background: #ffef8f url(resources/images/ui-bg_highlight-soft_25_ffef8f_1x100.png) 50% top repeat-x;    color: #363636;   margin: 5px; padding: 10px; -webkit-border-radius: 5px; -moz-border-radius: 5px; -ms-border-radius: 5px;  -o-border-radius: 5px;  border-radius: 5px;">
                            <hlayout>
                                <n:i class="z-icon-info"></n:i>
                                <label value="Lista de trámites documentarios registrados a la espera de firma digital o derivación, también aqui se puede aperturar un nuevo trámite documentario o responder un documento de mi bandeja de entrada en el boton 'Nuevo Registro'. " />
                            </hlayout>
                        </vlayout>
                
                        <listbox id="listSiado" width="100%"  emptyMessage="No hay Registros Encontrados"  multiple="true" checkmark="true"  nonselectableTags="button">
                                <auxhead sclass="category-center">                        
                                    <auxheader style="text-align:right"  colspan="9">
                                        <bandbox width="550px" id="filtro" instant="true" placeholder="Buscar..." sclass="input-prepend" />
                                    </auxheader>
                                </auxhead>
                                <auxhead sclass="category-center">
                                    <auxheader colspan="9">
                                        <button id="nuevo" iconSclass="z-icon-file">Nuevo</button>&#160;
                                        <button id="sendMultiple"  iconSclass="z-icon-plane" >Envio Múltiple</button>&#160;
                                        <!--<button id="eliminar" iconSclass="z-icon-trash-o">Borrar</button>&#160;     
                                        <button id="update" iconSclass="z-icon-refresh">Actualizar</button>        
                                        <button id="send" iconSclass="z-icon-plane">Enviar</button>-->              
                                    </auxheader>
                                </auxhead>
                            <!--<auxhead sclass="category-center">
                                <auxheader colspan="8" align="left">
                                    <button id="nuevo" sclass="btn-success"   autodisable="self"  zclass="btn" iconSclass="z-icon-file">Nuevo Registro</button>
                            
                                </auxheader>
                       
                                <auxheader style="text-align:right"  colspan="5">
                                    <bandbox width="550px" id="filtro" instant="true" placeholder="Buscar..." sclass="input-prepend" />
                                </auxheader>
                            </auxhead>-->
                   
                            <listhead sizable="true">
                                <listheader hflex="min" label="" align="left"/>
                                <listheader hflex="min" label="Titulo Habilitante" align="center" width="6%"/>
                                 <listheader align="left" label="Nro Trámite" width="10%" />
                                <listheader align="left" label="Fecha" width="10%" />
                                <listheader align="left" label="Usuario de Envio" width="10%" />
                                 <listheader align="left" label="Nro. Expediente" width="10%" />
                                <listheader align="left" label="Password" width="20%" />
                                <listheader align="left" label="Estado Tramite" width="15%" />
                                <listheader label="Opción" width="150px"></listheader>
                            </listhead>
                        </listbox>
                        <paging id="pagingData" pageSize="20" visible="true"/>
                
                    </div> 
                    <popup style="width:250px" id="popup" ></popup>
                    <div id="msnDivVentana" visible="false">
                        <div class="box-body">
                            <vlayout  style="background: #DC3545;border: 1px solid #B73545; color: #FFFFFF; margin: 5px; padding: 10px; -webkit-border-radius: 5px; -moz-border-radius: 5px; -ms-border-radius: 5px;  -o-border-radius: 5px;  border-radius: 5px;">
                                <hlayout>
                                    <n:i class="z-icon-info"></n:i>
                                    <label id="lblMsg"  />
                                </hlayout>
                            </vlayout>
                        </div>
                    </div>               
                
                   
                    <div id="nDivVentana" visible="false">    
                        <div class="box-body">
                            <div style="color:white;background-color:#00C0EF;font-style:italic;margin-top:10px; margin-bottom:20px; padding:5px;border:1px solid #00C0EF;border-bottom:0px; float:left; width:100%">
                                <label style="font-size:14px;font-weight:bold;" >ENCABEZADO DE ENVIO: SELECCIONE LAS OPCIONES CORRECTAS</label>
                            </div>
                            <grid  style="width:100%;" >
                                <columns>
                                    <column label="" width="20%" />
                                    <column label="" width="20%" />
                                    <column label="" width="20%" />
                                    <column label="" width="20%" />
                                    <column label="" width="20%" />
                                    
                                </columns>
                                <rows>
                                    <row>
                                        <vlayout >
                                            <label value="Serie documental:" /> 
                                            <listbox id="nCmbSerie" mold="select" width="100%"></listbox>
                                        </vlayout>
                                        
                                        <vlayout >
                                            <label value="Sub Serie Documental:" /> 
                                            <listbox id="nCmbSubSerie" mold="select" width="100%"></listbox>
                                        </vlayout>
                                        
                                        <vlayout >
                                            <label value="Titulo Habilitante: " /> 
                                            <textbox id="nTxtTitulo"  class="form-control" maxlength="250" style="text-transform: uppercase" placeholder="" />
                                            <label id="nTxtTituloError" />
                                        </vlayout>
                                        
                                         <vlayout >
                                            <label value="Titular:" /> 
                                            <textbox id="nTxtTitular" ></textbox>
                                        </vlayout>
                                        
                                        <vlayout >
                                            <label value="Descripción " /> 
                                            <textbox id="nTxtDescripcion1"  class="form-control" maxlength="250" style="text-transform: uppercase" placeholder="" />
                                        </vlayout>
                                        
                                        
                                 
                                    </row>
                                    <row>
                                        <vlayout >
                                            <label value="Mes Inicio" /> 
                                            <listbox id="nCmbMesAnio" mold="select" >
                                                <listitem value="01" label="Enero" selected="true"></listitem>
                                                <listitem value="02" label="Febrero" ></listitem>
                                                <listitem value="03" label="Marzo" ></listitem>
                                                <listitem value="04" label="Abril" ></listitem>
                                                <listitem value="05" label="Mayo" ></listitem>
                                                <listitem value="06" label="Junio" ></listitem>
                                                <listitem value="07" label="Julio" ></listitem>
                                                <listitem value="08" label="Agosto" ></listitem>
                                                <listitem value="09" label="Setiembre" ></listitem>
                                                <listitem value="10" label="Octubre" ></listitem>
                                                <listitem value="11" label="Noviembre" ></listitem>
                                                <listitem value="12" label="Diciembre" ></listitem>
                                            </listbox>
                                        </vlayout>
                                        
                                        <vlayout >
                                            <label value="Mes Fin" /> 
                                            <listbox id="nCmbMesFin" mold="select" >
                                                <listitem value="01" label="Enero" selected="true"></listitem>
                                                <listitem value="02" label="Febrero" ></listitem>
                                                <listitem value="03" label="Marzo" ></listitem>
                                                <listitem value="04" label="Abril" ></listitem>
                                                <listitem value="05" label="Mayo" ></listitem>
                                                <listitem value="06" label="Junio" ></listitem>
                                                <listitem value="07" label="Julio" ></listitem>
